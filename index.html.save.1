    </header> <div class="container"> 
        <h2>Menu Produk</h2>
        
        <!-- Produk 1 --> <div 
        class="produk-card">
            <div class="info-produk"> 
                <h3>Beras Premium 1kg</h3> 
                <p>Rp 15.000</p>
            </div> <button class="btn-beli" 
            onclick="tambahKeKeranjang('Beras 
            Premium 1kg', 15000)">+ 
            Beli</button>
        </div> <!-- Produk 2 --> <div 
        class="produk-card">
            <div class="info-produk"> 
                <h3>Minyak Goreng 1L</h3> 
                <p>Rp 18.000</p>
            </div> <button class="btn-beli" 
            onclick="tambahKeKeranjang('Minyak 
            Goreng 1L', 18000)">+ 
            Beli</button>
        </div> <!-- Produk 3 --> <div 
        class="produk-card">
            <div class="info-produk"> 
                <h3>Gula Pasir 1kg</h3> 
                <p>Rp 16.000</p>
            </div> <button class="btn-beli" 
            onclick="tambahKeKeranjang('Gula 
            Pasir 1kg', 16000)">+ 
            Beli</button>
        </div> <!-- Keranjang Belanja --> 
        <div class="keranjang-box">
            <div style="display: flex; 
            justify-content: space-between; 
            align-items: center;">
                <h3>🛒 Keranjang 
                Belanja</h3> <button 
                class="btn-reset" 
                onclick="kosongkanKeranjang()">Kosongkan</button>
            </div> <ul id="daftar-belanja"> 
                <!-- Item yang dibeli akan 
                muncul di sini otomatis --> 
                <li 
                id="pemberitahuan-kosong">Keranjang 
                masih kosong.</li>
            </ul> <div class="total-bayar"> 
                <span>Total:</span> <span 
                id="total-harga">Rp 
                0</span>
            </div> </div> </div> <!-- 
    Logika Aplikasi (JavaScript) --> 
    <script>
        let totalBelanja = 0; let 
        jumlahItem = 0; function 
        tambahKeKeranjang(namaProduk, 
        harga) {
            // Hapus tulisan "Keranjang 
            // masih kosong" jika ada item 
            // pertama masuk
            const pesanKosong = 
            document.getElementById('pemberitahuan-kosong'); 
            if (pesanKosong) {
                pesanKosong.remove();
            }
            // Tambah item ke dalam daftar 
            // <ul>
            const daftar = 
            document.getElementById('daftar-belanja'); 
            const itemBaru = 
            document.createElement('li'); 
            itemBaru.textContent = 
            `${namaProduk} - Rp 
            ${harga.toLocaleString('id-ID')}`; 
            daftar.appendChild(itemBaru);
            // Hitung total harga
            totalBelanja += harga; 
            document.getElementById('total-harga').textContent 
            = `Rp 
            ${totalBelanja.toLocaleString('id-ID')}`;
        }
        function kosongkanKeranjang() {
            // Kembalikan ke setelan awal
            document.getElementById('daftar-belanja').innerHTML 
            = '<li 
            id="pemberitahuan-kosong">Keranjang 
            masih kosong.</li>'; 
            totalBelanja = 0; 
            document.getElementById('total-harga').textContent 
            = "Rp 0";
        }
    </script> </body> </html> <div 
